# ─── Variables para el backend en RAILWAY ───────────────────────────────────
# Nunca pongas valores reales en este archivo ni lo subas con datos reales:
# solo sirve de plantilla. Configura los valores reales en el panel de
# variables de entorno de Railway.

# Clave secreta para firmar los tokens de sesión (JWT). Genera una aleatoria,
# por ejemplo con: openssl rand -hex 48
JWT_SECRET=

# Cuenta de administración/soporte que se crea automáticamente al arrancar.
# Se guarda SIEMPRE hasheada (bcrypt) en la base de datos, nunca en texto plano.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# URL pública de tu frontend en Vercel (se usa para construir el enlace de
# recuperación de contraseña que se envía por email).
APP_URL=https://tu-app.vercel.app

# Opcional: envío real de emails de recuperación vía Resend (resend.com).
# Si no se configuran, el enlace de recuperación se imprime en los logs
# del servidor (modo desarrollo).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Variables para el frontend en VERCEL ───────────────────────────────────
# URL del backend real en Railway
VITE_API_URL=https://mis-modelos-ia-propios-production.up.railway.app
