# Copia este archivo a .env y rellena valores reales.
# Nunca subas el archivo .env (con valores reales) a un repositorio público.

# ---------- Postgres ----------
POSTGRES_PASSWORD=cambia-esto-por-una-contraseña-fuerte

# ---------- LiteLLM ----------
# Genera claves aleatorias fuertes para estas dos, por ejemplo con:
#   openssl rand -hex 32
LITELLM_MASTER_KEY=sk-cambia-esta-clave-maestra
LITELLM_SALT_KEY=cambia-esta-clave-de-sal
LITELLM_UI_PASSWORD=cambia-esta-contraseña

# ---------- Ollama ----------
# URL donde corre tu servidor Ollama real (el que sirve los modelos
# zocoia-nano/core/pro). Si Ollama corre en la misma máquina fuera de Docker,
# usa http://host.docker.internal:11434
OLLAMA_API_BASE=http://host.docker.internal:11434

# ---------- Backend (server/main.py) ----------
JWT_SECRET=cambia-este-secreto-jwt
ADMIN_EMAIL=tu-email-real@ejemplo.com
ADMIN_PASSWORD=cambia-esta-contraseña-admin
