# Maris AI — Variables de entorno
# Copia este archivo a .env y rellena valores reales.
# NUNCA subas el archivo .env (con valores reales) a un repositorio publico.

# ─── Admin (OBLIGATORIAS — el servidor no arranca sin estas 3) ────────────────
ADMIN_EMAIL=tu-email@ejemplo.com
ADMIN_PASS=una-contrasena-fuerte-y-nueva

# ─── Gateway ──────────────────────────────────────────────────────────────────
# Clave maestra de administracion del gateway (para crear/revocar claves de clientes)
# Genera con: openssl rand -hex 32
ADMIN_KEY=sk-admin-cambia-esto-por-una-clave-fuerte

# Clave interna del agente (para que el agente pueda llamar al gateway)
AGENT_INTERNAL_KEY=sk-marisai-agente-interno-cambia-esto

# ─── Backend de inferencia ────────────────────────────────────────────────────
# Ollama corre de forma NATIVA en el host (no como contenedor Docker).
# host.docker.internal permite que los contenedores hablen con el host de Windows.
# Esta es la misma variable que usa docker-compose.yml para el servicio gateway.
VLLM_URL=http://host.docker.internal:11434/v1

# URL del servidor vLLM real (si en el futuro usas GPU en servidor externo con vLLM)
# VLLM_URL=http://TU_IP_GPU:8000/v1

# ─── Base de datos del gateway ────────────────────────────────────────────────
DB_PATH=/data/gateway.db

# ─── Facturacion (Viva.com) ───────────────────────────────────────────────────
# Credenciales de Viva.com para cobrar a clientes
# VIVA_MERCHANT_ID=tu-merchant-id
# VIVA_API_KEY=tu-api-key
# VIVA_SOURCE_CODE=tu-source-code

# ─── Configuracion del agente ─────────────────────────────────────────────────
AGENT_MODEL=maris-velox-1b
AGENT_MAX_ATTEMPTS=3
