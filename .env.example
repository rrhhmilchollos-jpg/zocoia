# ─── Variables para el backend en RAILWAY ───────────────────────────────────
# Nunca pongas valores reales en este archivo ni lo subas con datos reales:
# solo sirve de plantilla. Configura los valores reales en el panel de
# variables de entorno de Railway.

# Clave secreta para firmar los tokens de sesión (JWT). Genera una aleatoria,
# por ejemplo con: openssl rand -hex 48
JWT_SECRET=

# Cuenta de administración/soporte que se crea automáticamente al arrancar.
# Se guarda SIEMPRE hasheada (bcrypt) en la base de datos, nunca en texto plano.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# URL pública de tu frontend en Vercel (se usa para construir el enlace de
# recuperación de contraseña que se envía por email).
APP_URL=https://tu-app.vercel.app

# Opcional: envío real de emails de recuperación vía Resend (resend.com).
# Si no se configuran, el enlace de recuperación se imprime en los logs
# del servidor (modo desarrollo).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Motor de inferencia de Zoco IA ────────────────────────────────────────
# EXCLUSIVAMENTE OLLAMA LOCAL: por decisión de infraestructura NO se usa Groq
# ni ninguna API en la nube — todo el ecosistema trabaja con los modelos
# locales corriendo en Ollama. Los clientes externos NUNCA ven estos valores:
# ellos solo usan API Keys sk-zoco- generadas en el Dashboard → API Keys.
#
# URL del servidor de Ollama (endpoint OpenAI-compatible /v1). Default local:
OLLAMA_BASE_URL=http://127.0.0.1:11434
# API key para el endpoint /v1 de Ollama (acepta cualquier string):
OLLAMA_API_KEY=ollama
# Timeout en ms para las respuestas del modelo local (default 300000 = 5 min):
# OLLAMA_TIMEOUT_MS=300000
#
# Nombres EXACTOS de los modelos creados en tu servidor (ollama list).
# Si no se definen, se usan: Zoco-Flash, Zoco-Plus, Zoco-Max, Zoco-Lab.
# OLLAMA_MODEL_FLASH=Zoco-Flash
# OLLAMA_MODEL_PLUS=Zoco-Plus
# OLLAMA_MODEL_MAX=Zoco-Max
# OLLAMA_MODEL_LAB=Zoco-Lab

# ─── Cómo conectar MARIS AI a este backend ───────────────────────────────
# En el servicio de Railway de maris-ai (api-server y worker) configura:
#   ZOCOIA_API_URL = URL pública de ESTE backend (ej: https://xxx.up.railway.app)
#   ZOCOIA_API_KEY = una API Key sk-zoco- creada en el Dashboard → API Keys
# Con eso, todo el pipeline multi-agente de Maris AI (Researcher, Architect,
# Designer, Frontend, Backend, QA, Patcher...) viaja exclusivamente por Zoco IA
# a través de /v1/messages (formato Anthropic) y /v1/chat/completions (OpenAI).

# ─── Variables para el frontend en VERCEL ─────────────────────────────────
# URL del backend real en Railway
VITE_API_URL=https://mis-modelos-ia-propios-production.up.railway.app
